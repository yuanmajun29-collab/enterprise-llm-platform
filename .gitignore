# ========================================
# Enterprise LLM Platform .gitignore
# ========================================

# 模型文件 (太大，不适合 git)
models/
*.safetensors
*.bin
*.gguf

# Docker 数据
data/
logs/
*.log

# Docker 配置中的敏感信息
docker/.env

# IDE 插件构建产物
plugin/vscode/out/
plugin/vscode/node_modules/
plugin/vscode/*.vsix
plugin/vscode/.vscode-test/
plugin/jetbrains/build/
plugin/jetbrains/.gradle/
plugin/jetbrains/.idea/

# 操作系统
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# 备份文件
*.bak
backup*.sql
*.tar.gz

# 临时文件
*.tmp
temp/
tmp/

# 环境变量
.env
.env.local
.env.*.local

# 密钥和证书
*.pem
*.key
*.crt
*.p12
*.keystore

# IDE 配置
.vscode/
.idea/
*.iml

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 依赖目录
node_modules/
bower_components/

# 测试覆盖率
coverage/
.nyc_output/

# 构建目录
dist/
build/
out/

# 缓存
.cache/
.parcel-cache/
.next/
.nuxt/
.vuepress/dist/
.serverless/
.fusebox/
.dynamodb/
.tern-port/

# TypeScript
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
env/
ENV/
models/
data/
logs/
